{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "My first API Gateway - KrakenD",
  "port": 8080,
  "host": ["http://localhost:8080"],
  "endpoints": [
    {
      "endpoint": "/encodings.json",
      "backend": [
        {
          "url_pattern": "/media/response.json",
          "encoding": "json",
          "group": "json"
        },
        {
          "url_pattern": "/media/response.xml",
          "encoding": "xml",
          "group": "xml"
        },
        {
          "url_pattern": "/media/response.rss",
          "encoding": "rss",
          "group": "rss"
        },
        {
          "url_pattern": "/media/response.txt",
          "encoding": "string",
          "group": "string"
        }
      ]
    },
    {
      "endpoint": "/encodings.xml",
      "backend": [
        {
          "host": ["http://localhost:8080"],
          "url_pattern": "/encodings.json"
        }
      ],
      "output_encoding": "xml"
    }
  ],
  "extra_config": {
    "server/static-filesystem": {
      "prefix": "/media/",
      "path": "./data"
    }
  }
}
