{
  "$schema": "https://krakend.io/schema/krakend.json",
  "version": 3,
  "host": ["http://localhost:8080"],
  "echo_endpoint": true,
  "debug_endpoint": true,
  "plugin": {
    "folder": "/opt/krakend/plugins/",
    "pattern": ".so"
  },
  "extra_config": {
    "redis": {
      "connection_pools": [
        {
          "address": "redis:6379",
          "name": "local_instance",
          "db": 1
        }
      ]
    }
  },
  "endpoints": [
    {
      "endpoint": "/",
      "backend": [
        {
          "url_pattern": "/__echo/"
        }
      ],
      "extra_config": {
        "plugin/middleware": {
          "name": ["counter-example-mw"],
          "counter-example-mw": {
            "key_prefix": "foo-counter"
          }
        }
      }
    }
  ]
}