{
    "version": 3,
    "debug_endpoint": true,
    "host": ["http://localhost:8080"],
    "async_agent": [
        {
            "name": "stocksconsumer",
            "extra_config": {
                "async/kafka": {
                    "group_id": "my_group_id",
                    "topics": [
                        "krafka"
                    ],
                    "connection": {
                        "brokers": [
                            "localhost:9092"
                        ],
                        "client_id": "bartolo"
                    },
                    "consumer": {}
                }
            },
            "connection": {
                "max_retries": 2,
